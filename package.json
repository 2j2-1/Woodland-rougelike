{
  "name": "circuit-grove",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-manifest": "npx ts-node --esm scripts/generateManifest.ts",
    "db:migrate": "ts-node --esm scripts/migrateDb.ts"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "howler": "^2.2.4",
    "phaser": "^3.80.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/howler": "^2.2.11",
    "@types/node": "^20.17.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.2",
    "vitest": "^2.1.0"
  }
}
